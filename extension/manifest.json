{
  "manifest_version": 3,
  "name": "Autoflow Bridge",
  "version": "0.0.4",
  "description": "Local bridge that proxies Autoflow agent requests to authenticated labs.google sessions.",
  "permissions": ["storage", "alarms", "tabs", "webRequest", "scripting", "declarativeNetRequest"],
  "host_permissions": [
    "https://aisandbox-pa.googleapis.com/*",
    "https://labs.google/*",
    "http://127.0.0.1:8100/*",
    "http://localhost:8100/*"
  ],
  "icons": {
    "16":  "icons/icon-dark-16.png",
    "32":  "icons/icon-dark-32.png",
    "48":  "icons/icon-dark-48.png",
    "128": "icons/icon-dark-128.png"
  },
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_title": "Autoflow Bridge",
    "default_popup": "popup.html",
    "default_icon": {
      "16":  "icons/icon-dark-16.png",
      "32":  "icons/icon-dark-32.png",
      "48":  "icons/icon-dark-48.png",
      "128": "icons/icon-dark-128.png"
    }
  },
  "content_scripts": [
    {
      "matches": [
        "https://labs.google/fx/tools/flow*",
        "https://labs.google/fx/*/tools/flow*"
      ],
      "js": ["content.js"],
      "run_at": "document_start"
    }
  ],
  "web_accessible_resources": [
    {
      "resources": ["injected.js"],
      "matches": ["https://labs.google/*"]
    }
  ],
  "declarative_net_request": {
    "rule_resources": [
      {
        "id": "flowboard_rules",
        "enabled": true,
        "path": "rules.json"
      }
    ]
  }
}
